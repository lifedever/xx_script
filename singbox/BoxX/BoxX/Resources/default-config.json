{
  "dns": {
    "final": "dns_proxy",
    "independent_cache": true,
    "rules": [
      {
        "action": "route",
        "ip_accept_any": true,
        "server": "hosts"
      },
      {
        "action": "route",
        "clash_mode": "Direct",
        "server": "dns_direct"
      },
      {
        "action": "route",
        "clash_mode": "Global",
        "server": "dns_proxy"
      },
      {
        "action": "route",
        "domain_suffix": [
          "manyibar.cn",
          "manyibar.com",
          "manyiba.com",
          "kanasinfo.cn",
          "local",
          "localhost",
          "internal"
        ],
        "server": "dns_direct"
      },
      {
        "action": "reject",
        "rule_set": [
          "geosite-ads"
        ]
      },
      {
        "action": "route",
        "process_name": [
          "WeChat",
          "WeChat Helper",
          "QQ",
          "AliPay",
          "DingTalk",
          "Feishu",
          "WeCom"
        ],
        "server": "dns_direct"
      },
      {
        "action": "route",
        "rule_set": [
          "geosite-cn",
          "geosite-apple-cn",
          "geosite-microsoft-cn",
          "geosite-google-cn"
        ],
        "server": "dns_direct"
      },
      {
        "action": "route",
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "dns_fakeip"
      }
    ],
    "servers": [
      {
        "tag": "hosts",
        "type": "hosts"
      },
      {
        "detour": "Proxy",
        "server": "8.8.8.8",
        "tag": "dns_proxy",
        "type": "https"
      },
      {
        "tag": "dns_local",
        "type": "local"
      },
      {
        "server": "223.5.5.5",
        "tag": "dns_direct",
        "type": "udp"
      },
      {
        "inet4_range": "198.18.0.0/15",
        "tag": "dns_fakeip",
        "type": "fakeip"
      }
    ],
    "strategy": "ipv4_only"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_fakeip": true,
      "store_rdrc": false
    },
    "clash_api": {
      "default_mode": "rule",
      "external_controller": "127.0.0.1:9091",
      "secret": ""
    }
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
